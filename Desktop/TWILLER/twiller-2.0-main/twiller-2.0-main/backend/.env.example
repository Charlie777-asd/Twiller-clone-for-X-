PORT=5000
PUBLIC_SERVER_URL=http://localhost:5000
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/twiller

# Set to false in production unless you explicitly want fallback behavior.
ALLOW_MOCK_SERVICES=true
ALLOW_MOCK_PAYMENTS=true

# ── Nodemailer SMTP Transport (Gmail) ──────
# Send from your personal Gmail address securely using an App Password.
#
# SETUP:
#   1. Go to your Google Account -> Security.
#   2. Enable 2-Step Verification if not already enabled.
#   3. Search for "App Passwords" and create a new one.
#   4. Copy the 16-character password and paste it below without spaces.
#
EMAIL=your.address@gmail.com
EMAIL_PASSWORD=xxxxxxxxxxxxxxxx

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=whatsapp:+14155238886

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Cloudinary Storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
