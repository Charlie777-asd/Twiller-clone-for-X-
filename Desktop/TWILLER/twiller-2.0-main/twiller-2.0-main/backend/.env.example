PORT=5000
PUBLIC_SERVER_URL=http://localhost:5000
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/twiller

# Set to false in production unless you explicitly want fallback behavior.
ALLOW_MOCK_SERVICES=true
ALLOW_MOCK_PAYMENTS=true

# ── Gmail REST API Transport (HTTPS port 443 — bypasses Render SMTP firewall) ──
# Uses your personal Gmail account with no custom domain required.
# App Password + SMTP (port 465/587) is blocked by Render. This uses the
# Gmail REST API over HTTPS port 443 instead.
#
# ONE-TIME SETUP (takes ~5 min):
#   1. console.cloud.google.com → New Project → Enable "Gmail API"
#   2. OAuth consent screen → External → add scope: .../auth/gmail.send
#   3. Credentials → OAuth 2.0 Client ID → Web app
#      Redirect URI: https://developers.google.com/oauthplayground
#      Copy CLIENT_ID and CLIENT_SECRET below.
#   4. Open https://developers.google.com/oauthplayground
#      Gear icon → "Use your own OAuth credentials" → paste client creds
#      Scope: https://www.googleapis.com/auth/gmail.send → Authorize
#      "Exchange authorization code for tokens" → copy Refresh token.
#   5. Paste all four values into Render Dashboard → Environment.
#
GMAIL_USER=your.address@gmail.com
GMAIL_CLIENT_ID=123456789-abc.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxx
GMAIL_REFRESH_TOKEN=1//0gxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=whatsapp:+14155238886

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
